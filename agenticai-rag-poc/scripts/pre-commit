#!/usr/bin/env python3
"""Pre-commit hook — strict secrets and sensitive-data audit.

Installed automatically by scripts/local/setup.sh.
Run manually: python3 scripts/pre-commit

Blocks a commit when any staged file contains:
  • .env files (secrets may be present)
  • OpenAI API keys (sk-... / sk-proj-...)
  • LangSmith API keys (ls__... / lsv2_...)
  • Vercel Blob read/write tokens
  • GitHub personal access tokens
  • Pinecone API keys assigned to config variables
  • 64-char hex strings assigned to SECRET_KEY in source code

Length-discriminating patterns are used throughout so that known short
test placeholders (e.g. "sk-test-key", "pc-fake-key") are not flagged.
"""

from __future__ import annotations

import re
import subprocess
import sys
from dataclasses import dataclass, field
from pathlib import Path

# ── Files never scanned for content ──────────────────────────────────────────
SKIP_CONTENT_SCAN: frozenset[str] = frozenset({
    # This script itself contains the patterns as string literals
    "scripts/pre-commit",
    # Example / template env files are intentionally placeholder-filled
    "backend/.env.example",
})

SKIP_EXTENSIONS: frozenset[str] = frozenset({
    ".png", ".jpg", ".jpeg", ".gif", ".ico", ".svg",
    ".woff", ".woff2", ".ttf", ".eot",
    ".zip", ".tar", ".gz", ".pdf",
    ".pyc", ".pyo", ".so", ".dll", ".exe",
    ".lock",           # lock files contain hashes, not secrets
    ".map",            # source maps
})


# ── Detection rules ───────────────────────────────────────────────────────────
@dataclass
class Rule:
    description: str
    pattern: re.Pattern[str]
    # Lines matching any safe_pattern are exempt from this rule.
    safe_patterns: list[re.Pattern[str]] = field(default_factory=list)


RULES: list[Rule] = [
    # OpenAI API key — real keys are 51+ chars (sk- + 48).
    # Short placeholders like "sk-test-key" (11 chars) won't match.
    Rule(
        description="OpenAI API key",
        pattern=re.compile(r'sk(-proj)?-[A-Za-z0-9_\-]{40,}'),
        safe_patterns=[
            re.compile(r'sk-test-'),
            re.compile(r'sk-fake'),
            re.compile(r'sk-mock'),
            re.compile(r'sk-xxx'),
        ],
    ),
    # LangSmith / LangChain API key — real keys are 30+ chars after prefix.
    Rule(
        description="LangSmith API key",
        pattern=re.compile(r'(ls__|lsv2_)[A-Za-z0-9_\-]{25,}'),
        safe_patterns=[
            re.compile(r'ls__runtime-key'),   # known test placeholder
            re.compile(r'lsv2_test'),
        ],
    ),
    # Vercel Blob read/write token.
    Rule(
        description="Vercel Blob read/write token",
        pattern=re.compile(r'vercel_blob_rw_[A-Za-z0-9_\-]{20,}', re.IGNORECASE),
    ),
    # GitHub personal access / installation tokens.
    Rule(
        description="GitHub token",
        pattern=re.compile(r'(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{36,}'),
    ),
    # Pinecone API key assigned to a config variable.
    # Matches only when the UUID appears directly after a Pinecone key assignment
    # so random UUIDs in log output or test IDs are not flagged.
    Rule(
        description="Pinecone API key in assignment",
        pattern=re.compile(
            r'pinecone_api_key\s*[=:]\s*[\'"]'
            r'[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}'
            r'[\'"]',
            re.IGNORECASE,
        ),
        safe_patterns=[
            re.compile(r'pc-fake'),
            re.compile(r'pc-test'),
            re.compile(r'pc-mock'),
            re.compile(r'00000000-0000-0000-0000-000000000000'),
        ],
    ),
    # SECRET_KEY assigned a 64-char hex string in source code.
    # Real keys from `openssl rand -hex 32` are exactly 64 hex chars.
    # Test values like "test-secret-key-for-testing-only-32ch" contain non-hex chars.
    Rule(
        description="Hardcoded SECRET_KEY (64-char hex) in source",
        pattern=re.compile(
            r'(SECRET_KEY|secret_key)\s*[=:]\s*[\'"]?[0-9a-f]{64}[\'"]?'
        ),
    ),
    # Generic high-entropy password assigned to ADMIN_PASSWORD or password= in
    # non-test source files.  Only triggered when the value is 20+ chars and
    # contains no obviously-fake markers.
    Rule(
        description="Hardcoded ADMIN_PASSWORD in source (non-test)",
        pattern=re.compile(
            r'(ADMIN_PASSWORD|admin_password)\s*[=:]\s*[\'"][^\'"]{20,}[\'"]'
        ),
        safe_patterns=[
            re.compile(r'TestPass'),
            re.compile(r'test.*pass', re.IGNORECASE),
            re.compile(r'fake.*pass', re.IGNORECASE),
            re.compile(r'your.*password', re.IGNORECASE),
            re.compile(r'<your'),
            re.compile(r'example'),
            re.compile(r'placeholder'),
            re.compile(r'generated'),
            re.compile(r'auto.*gen', re.IGNORECASE),
            re.compile(r'\$\('),     # shell command substitution (auto-generate)
            re.compile(r'\$\{'),     # shell / template variable
            re.compile(r'secrets\.token'),   # Python secrets.token_*
        ],
    ),
]


# ── Git helpers ───────────────────────────────────────────────────────────────

def staged_files(ci_mode: bool = False) -> list[str]:
    """Return files to scan.

    ci_mode=True: all tracked files in the working tree (for GitHub Actions).
    ci_mode=False: only staged (index) files, as used by the local git hook.
    """
    if ci_mode:
        result = subprocess.run(
            ["git", "ls-files"],
            capture_output=True, text=True, check=True,
        )
    else:
        result = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
            capture_output=True, text=True, check=True,
        )
    return [f for f in result.stdout.splitlines() if f]


def staged_content(path: str, ci_mode: bool = False) -> str | None:
    """Return file content to scan, or None if unreadable/binary.

    ci_mode=True: read the working-tree file directly.
    ci_mode=False: read the staged (index) version via `git show`.
    """
    try:
        if ci_mode:
            return Path(path).read_text(encoding="utf-8", errors="replace")
        result = subprocess.run(
            ["git", "show", f":{path}"],
            capture_output=True, check=True,
        )
        return result.stdout.decode("utf-8", errors="replace")
    except (subprocess.CalledProcessError, OSError):
        return None


# ── Main audit ────────────────────────────────────────────────────────────────

@dataclass
class Finding:
    path: str
    line_no: int
    description: str
    excerpt: str  # truncated, redacted


def _redact(text: str, match: re.Match[str]) -> str:
    """Show only the first 6 chars of the matched secret."""
    start, end = match.span()
    prefix = text[max(0, start - 20):start].lstrip()
    secret_preview = text[start:start + 6] + "****"
    return f"{prefix}{secret_preview}"


def audit_file(path: str, ci_mode: bool = False) -> list[Finding]:
    if path in SKIP_CONTENT_SCAN:
        return []
    if Path(path).suffix in SKIP_EXTENSIONS:
        return []

    content = staged_content(path, ci_mode=ci_mode)
    if content is None:
        return []

    findings: list[Finding] = []
    for line_no, line in enumerate(content.splitlines(), start=1):
        for rule in RULES:
            m = rule.pattern.search(line)
            if m is None:
                continue
            if any(sp.search(line) for sp in rule.safe_patterns):
                continue
            findings.append(Finding(
                path=path,
                line_no=line_no,
                description=rule.description,
                excerpt=_redact(line.strip(), m),
            ))
    return findings


def check_env_files(files: list[str]) -> list[str]:
    """Return any staged .env files (not .env.example)."""
    blocked: list[str] = []
    for f in files:
        name = Path(f).name
        if name.startswith(".env") and not name.endswith(".example"):
            blocked.append(f)
    return blocked


def main() -> int:
    ci_mode = "--ci" in sys.argv

    try:
        files = staged_files(ci_mode=ci_mode)
    except subprocess.CalledProcessError as exc:
        print(f"[pre-commit] git command failed: {exc}", file=sys.stderr)
        return 1

    if not files:
        return 0

    blocked_envs = check_env_files(files) if not ci_mode else []
    all_findings: list[Finding] = []
    for f in files:
        all_findings.extend(audit_file(f, ci_mode=ci_mode))

    if not blocked_envs and not all_findings:
        return 0

    # ── Print report ──────────────────────────────────────────────────────────
    RED   = "\033[0;31m"
    YELLOW = "\033[1;33m"
    BOLD  = "\033[1m"
    NC    = "\033[0m"

    print()
    print(f"{RED}{BOLD}╔══════════════════════════════════════════════════════════╗{NC}")
    print(f"{RED}{BOLD}║  COMMIT BLOCKED — potential secrets detected             ║{NC}")
    print(f"{RED}{BOLD}╚══════════════════════════════════════════════════════════╝{NC}")
    print()

    if blocked_envs:
        print(f"{YELLOW}  .env files staged (may contain live secrets):{NC}")
        for f in blocked_envs:
            print(f"    • {f}")
        print()
        print("  Remove them from the commit:")
        for f in blocked_envs:
            print(f"    git restore --staged {f}")
        print()

    if all_findings:
        print(f"{YELLOW}  Sensitive-data patterns found in staged files:{NC}")
        print()
        for finding in all_findings:
            print(f"  {BOLD}{finding.path}{NC}:{finding.line_no}  [{finding.description}]")
            print(f"    {finding.excerpt}")
            print()

    print("  Fix the issues above, then re-stage and commit.")
    print("  If a match is a false positive, add it to the safe_patterns")
    print("  in scripts/pre-commit and re-run setup.sh to reinstall the hook.")
    print()

    return 1


if __name__ == "__main__":
    sys.exit(main())
