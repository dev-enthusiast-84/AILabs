# Env files — NEVER commit secrets.
# backend/.env holds ADMIN_PASSWORD and SECRET_KEY generated at runtime;
# it is intentionally excluded from version control.
.env
**/.env
backend/.env
backend/.env.*
**/.env.local
**/.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
.pytest_cache/
.mypy_cache/

# Vector store (can be large)
backend/chroma_db/

# Original uploaded files (served at runtime, not committed)
backend/uploads/

# Node
node_modules/
frontend/dist/

# Test reports (generated, not committed)
test-reports/

# Sample data files — generated locally, not committed
# Run: python sample-data/generate_samples.py
sample-data/sample.txt
sample-data/sample.csv
sample-data/sample.xlsx
sample-data/sample.pdf

# OS
.DS_Store
../.DS_Store
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
**/.claude/
.vercel/
.vercel
.env*.local
backend/.env.*
frontend/.env*

# Frontend generated reports/artifacts
frontend/playwright-report/
frontend/test-results/
playwright-report/
test-results/

PENDING_TASKS.md
artifacts/

# Generated — produced by CI (deploy-docs.yml) and `make docs-readme`; do not commit
docs/README.md

# Submission zip — regenerate with: bash scripts/package-submission.sh
agentic-rag-poc-submission.zip